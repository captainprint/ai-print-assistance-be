PORT=5000
MONGODB_URI=mongodb://localhost:27017/print-assistance
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
FRONTEND_URL=http://localhost:3000
NODE_ENV=development
WC_STORE_URL=https://your-store.com
WC_API_KEY=your_wc_consumer_key
WC_API_SECRET=your_wc_consumer_secret

# Where customer-facing "resume conversation" magic links point (the
# storefront's floating chat widget, not this app). Defaults to staging;
# set to https://captainprint.com in the production environment.
CUSTOMER_APP_URL=https://staging13.captainprint.com

# Required for handoff emails (staff/customer notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM="PrintAssistance" <your_email@gmail.com>

# Required in production: authorizes Vercel Cron to call /api/v1/cron/*
# (Vercel auto-sends "Authorization: Bearer <CRON_SECRET>" to cron requests)
CRON_SECRET=generate_a_long_random_string
