{
  "functions": {
    "api/index.js": { "maxDuration": 30 }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ],
  "crons": [
    { "path": "/api/v1/cron/sync-products", "schedule": "0 2 * * *" },
    { "path": "/api/v1/cron/purge-tokens", "schedule": "0 3 * * *" }
  ]
}
